---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResumePreview from '../components/ResumePreview.astro';
---

<BaseLayout>
	<section id="top" class="hero">
    	<p class="eyebrow">// student, lifter of weights, follower of Christ </p>
    	<h1>Micah</h1>
		<h1><span class="highlight">Livingston</span></h1>
		<div class="hero-cta">
			<a href="#about-me" class="btn ghost">learn more</a>
    		<a href="#contact" class="btn ghost">get in touch</a>
		</div>
	</section>

	<section id="about-me">
		<div class="section-head">
			<div class="section-num">01</div>
			<h2>About Me</h2>
		</div>
		<hr class="divider">
		<div class="section-body">
			<p>My name is Micah Livingston. 
				I am a senior at the University of Arkansas planning to graduate with my B.S. in Computer Engineering in May 2027. I am also pursuing minors in Mathematics and Engineering Management.
				Outside of the classroom I enjoy lifting weights as often as possible. Aside from pure enjoyment of the process, my love for weightlifting is driven by a long term goal of competing as a natural bodybuilder. While lifting is just one of my hobbies, it is definitely the one I devote the most time and attention to.
				On the university campus I am highly involved with a campus ministry known as RUF (Reformed University Fellowship). RUF has been a pivotal part of my college experience where I have been able to grow in my faith while simultaneously growing in relationship with others.
				This is just a snippet into my life, if you would like to learn more follow the links below!
			</p>
			<div class="section-cta">
				<a href="/engineering/" class="btn ghost" target="_blank" rel="noopener">engineering</a>
				<a href="/lifting/" class="btn ghost" target="_blank" rel="noopener">lifting</a>
				<a href="/hobbies/" class="btn ghost" target="_blank" rel="noopener">hobbies</a>
			</div>
		</div>
		<hr class="divider">
	</section>

	<section id="resume">
		<div class="section-head">
			<div class="section-num">02</div>
			<h2>Resume</h2>
		</div>
		<hr class="divider">
		<div class="section-body">
			<p>Take a look at my resume!</p>
			<div class="section-cta">
				<a href="/resume.pdf" class="btn ghost" target="_blank" rel="noopener">view full resume</a>
				<a href="/resume.pdf" class="btn ghost" download="Micah-Livingston-Resume.pdf">download resume</a>
				<a><button type="button" class="btn ghost" id="preview-toggle">preview resume</button></a>
			</div>
		</div>
		<details class="resume-dropdown" id="resume-details">
			<summary style="display: none;"></summary>
			<div class="preview-content">
				<iframe src="/resume.pdf" title="Resume preview"></iframe>
			</div>
		</details>
		<hr class="divider">
	</section>

	<script>
		const toggleBtn = document.getElementById('preview-toggle');
		const details = document.getElementById('resume-details');

		toggleBtn?.addEventListener('click', () => {
		details.open = !details.open;
		toggleBtn.textContent = details.open ? 'hide preview ' : 'preview resume ';
		toggleBtn.classList.toggle('open', details.open);
		});
	</script>

	<section id="contact">
		<div class="section-head">
			<div class="section-num">03</div>
			<h2>contact</h2>
		</div>
		<hr class="divider">
		<div class="section-body">
			<p>Let's get in touch!</p>
			<p>Personal Email: micahlivingston04@gmail.com</p>
			<p>School Email: micahl@uark.edu</p>
			<p>Work Email: coming soon?</p>
			<p>Phone Number: (918) 807 - 7123</p>
		</div>
		<hr class="divider">
	</section>
</BaseLayout>
