---
import { Image } from "astro:assets";
import logoLight from "../assets/logo-chalk.svg";
import logoDark from "../assets/logo-black.svg";
---

<div class="nav-logo">
  <Image
    src={logoLight}
    alt="Company Logo"
    width="100"
    height="100"
    class="logo logo-dark"
  />
  <Image
    src={logoDark}
    alt="Company Logo"
    width="100"
    height="100"
    class="logo logo-light"
  />
</div>

<style>
  .nav-logo {
    position: relative;
    width: 75px;
    height: 75px;
  }

  .logo {
    position: absolute;
    top: -10;
    left: -10;
  }

  .logo-light {
    opacity: 0;
    pointer-events: none;
  }

  :global(.light) .logo-dark {
    opacity: 0;
    pointer-events: none;
  }

  :global(.light) .logo-light {
    opacity: 1;
    pointer-events: auto;
  }
</style>
